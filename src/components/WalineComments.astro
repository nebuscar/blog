---
type Props = { commentPath: string };
const { commentPath } = Astro.props;
---

<section
  class="waline-comments app-layout"
  aria-labelledby="comments-title"
  data-comment-path={commentPath}
>
  <hr class="my-8 border-dashed" />
  <h2 id="comments-title" class="mb-6 text-2xl font-bold">评论</h2>
  <div id="waline-comments"></div>
</section>

<script>
  import { init, type WalineInstance } from "@waline/client";
  import { enhanceWalineKaomoji } from "@/scripts/walineKaomoji.mjs";

  type WalineWindow = Window & {
    __walineInstance?: WalineInstance | null;
    __walineKaomojiCleanup?: (() => void) | null;
    __walineLifecycleBound?: boolean;
  };

  function setupWaline() {
    const container = document.querySelector<HTMLElement>("#waline-comments");
    if (!container) return;

    const walineWindow = window as WalineWindow;
    walineWindow.__walineInstance?.destroy();
    walineWindow.__walineKaomojiCleanup?.();
    container.replaceChildren();

    walineWindow.__walineInstance = init({
      el: container,
      serverURL: "https://comment.okisama.top",
      path: container.closest<HTMLElement>("[data-comment-path]")?.dataset
        .commentPath,
      lang: "zh-CN",
      dark: "html[data-theme='dark']",
      login: "enable",
      commentSorting: "latest",
      imageUploader: false,
      search: false,
      emoji: [
        "https://unpkg.com/@waline/emojis@1.4.0/tw-emoji",
        "https://unpkg.com/@waline/emojis@1.4.0/bilibili",
      ],
      reaction: false,
    });
    walineWindow.__walineKaomojiCleanup = enhanceWalineKaomoji(container);
  }

  setupWaline();

  const walineWindow = window as WalineWindow;
  if (!walineWindow.__walineLifecycleBound) {
    walineWindow.__walineLifecycleBound = true;
    document.addEventListener("astro:before-swap", () => {
      walineWindow.__walineInstance?.destroy();
      walineWindow.__walineInstance = null;
      walineWindow.__walineKaomojiCleanup?.();
      walineWindow.__walineKaomojiCleanup = null;
    });
    document.addEventListener("astro:page-load", setupWaline);
  }
</script>

<style is:global>
  .waline-comments {
    margin-top: 1rem;
    margin-bottom: 3rem;
  }

  #comments-title {
    scroll-margin-top: 6rem;
  }

  #waline-comments {
    --waline-theme-color: var(--accent);
    --waline-active-color: var(--accent);
    --waline-color: var(--foreground);
    --waline-bg-color: var(--background);
    --waline-bg-color-light: var(--muted);
    --waline-bg-color-hover: color-mix(
      in srgb,
      var(--accent) 10%,
      var(--background)
    );
    --waline-border-color: var(--border);
    --waline-info-bg-color: var(--muted);
    --waline-info-color: var(--muted-foreground);
  }

  #waline-comments .wl-panel,
  #waline-comments .wl-card {
    box-sizing: border-box;
  }

  #waline-comments .wl-emoji-popup.waline-kaomoji-active > .wl-tab-wrapper {
    display: none;
  }

  #waline-comments .waline-kaomoji-panel {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(7.5rem, 1fr));
    gap: 0.25rem;
    min-height: 10rem;
    max-height: 18rem;
    overflow-y: auto;
    padding: 0.75rem;
  }

  #waline-comments
    .wl-emoji-popup:not(.waline-kaomoji-active)
    .waline-kaomoji-panel {
    display: none;
  }

  #waline-comments .waline-kaomoji-panel button {
    border-radius: 0.45rem;
    padding: 0.45rem 0.35rem;
    color: var(--foreground);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  #waline-comments .waline-kaomoji-panel button:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  #waline-comments .wl-tabs .wl-tab {
    width: auto;
    min-width: 5.5rem;
    padding-inline: 0.9rem;
  }

  #waline-comments .wl-tabs .wl-tab > img {
    display: none;
  }

  #waline-comments .waline-emoji-tab-label,
  #waline-comments .waline-kaomoji-tab {
    color: inherit;
    font-size: 0.9rem;
    font-weight: 600;
  }

  @media (max-width: 639px) {
    #waline-comments .waline-kaomoji-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    #waline-comments .wl-tabs .wl-tab {
      min-width: 0;
      padding-inline: 0.65rem;
    }
  }
</style>
