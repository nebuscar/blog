---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import config from "@/config";
import { useTranslations } from "@/i18n";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = {
  class?: string;
  size?: "sm" | "lg";
  pubDatetime: string | Date;
  timezone?: string;
  modDatetime?: string | Date | null;
};

const {
  pubDatetime,
  modDatetime,
  size = "sm",
  class: className = "",
  timezone: postTimezone,
} = Astro.props;

const t = useTranslations(Astro.currentLocale);

const siteTimezone = postTimezone ?? config.site.timezone;
const publishedDatetime = dayjs(pubDatetime).tz(siteTimezone);
const updatedDatetime = modDatetime ? dayjs(modDatetime).tz(siteTimezone) : null;
const shouldShowUpdatedDatetime = Boolean(updatedDatetime);

const publishedDate = publishedDatetime.format("YYYY-MM-DD HH:mm");
const updatedDate = updatedDatetime?.format("YYYY-MM-DD HH:mm");
---

<div
  class:list={[
    "text-muted-foreground flex flex-wrap items-center gap-x-2 gap-y-1",
    className,
  ]}
>
  <IconCalendar
    class:list={[
      "inline-block size-6 min-w-5.5",
      { "scale-90": size === "sm" },
    ]}
  />
  <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
    {t.post.publishedAt}:
  </span>
  <time
    class:list={["text-sm", { "sm:text-base": size === "lg" }]}
    datetime={publishedDatetime.toISOString()}
  >
    {publishedDate}
  </time>
  {
    shouldShowUpdatedDatetime && updatedDatetime && (
      <>
        <span aria-hidden="true" class="text-sm">
          ·
        </span>
        <span class:list={["text-sm", { "sm:text-base": size === "lg" }]}>
          {t.post.updatedAt}:
        </span>
        <time
          class:list={["text-sm", { "sm:text-base": size === "lg" }]}
          datetime={updatedDatetime.toISOString()}
        >
          {updatedDate}
        </time>
      </>
    )
  }
</div>
