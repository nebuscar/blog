---
import { musicPlayerConfig } from "@/config/musicConfig";

const config = JSON.stringify(musicPlayerConfig);
---

{
  musicPlayerConfig.enabled && (
    <aside
      id="music-player"
      class="music-player"
      aria-label="音乐播放器"
      transition:persist="music-player"
    >
      <button
        id="music-player-toggle"
        class="music-player-toggle"
        type="button"
        aria-label="收起音乐播放器"
        aria-expanded="true"
      >
        <svg class="collapse-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="m15 18-6-6 6-6" />
        </svg>
        <svg class="music-icon" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 18V5l11-2v13" />
          <circle cx="6" cy="18" r="3" />
          <circle cx="17" cy="16" r="3" />
        </svg>
      </button>
      <header class="music-header">
        <span aria-hidden="true"></span>
        <strong>音乐</strong>
      </header>

      <div class="music-track">
        <img id="music-cover" alt="" hidden />
        <div class="music-meta">
          <strong id="music-title">正在加载音乐...</strong>
          <span id="music-artist">QQ 音乐</span>
        </div>
        <button
          id="music-lyrics-toggle"
          class="icon-button"
          type="button"
          aria-label="展开歌词"
          aria-expanded="false"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="4" width="18" height="16" rx="2" />
            <path d="M7 9h10M7 13h7M7 17h4" />
          </svg>
        </button>
        <button id="music-mute" class="icon-button" type="button" aria-label="静音">
          <svg class="volume-on" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M11 5 6 9H3v6h3l5 4V5Z" />
            <path d="M15 9a4 4 0 0 1 0 6M18 6a8 8 0 0 1 0 12" />
          </svg>
          <svg class="volume-off" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M11 5 6 9H3v6h3l5 4V5Z" />
            <path d="m16 9 5 6m0-6-5 6" />
          </svg>
        </button>
      </div>

      <div class="music-timeline">
        <span id="music-current">0:00</span>
        <span>/</span>
        <span id="music-duration">0:00</span>
        <label>
          <span class="sr-only">音量</span>
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M11 5 6 9H3v6h3l5 4V5Z" />
            <path d="M15 9a4 4 0 0 1 0 6M18 6a8 8 0 0 1 0 12" />
          </svg>
          <input
            id="music-volume"
            type="range"
            min="0"
            max="1"
            step="0.05"
            value={musicPlayerConfig.volume}
            aria-label="音量"
          />
        </label>
      </div>

      <input
        id="music-seek"
        class="music-seek"
        type="range"
        min="0"
        max="100"
        value="0"
        aria-label="播放进度"
      />

      <div class="music-controls">
        <button id="music-loop" class="icon-button" type="button" aria-label="循环播放">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="m17 2 4 4-4 4M3 11V9a3 3 0 0 1 3-3h15M7 22l-4-4 4-4m14-1v2a3 3 0 0 1-3 3H3" />
          </svg>
        </button>
        <button id="music-prev" class="icon-button" type="button" aria-label="上一首">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M6 5v14M18 6 8 12l10 6V6Z" />
          </svg>
        </button>
        <button id="music-play" class="play-button" type="button" aria-label="播放">
          <svg class="play-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="m8 5 11 7-11 7V5Z" />
          </svg>
          <svg class="pause-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M8 5v14M16 5v14" />
          </svg>
        </button>
        <button id="music-next" class="icon-button" type="button" aria-label="下一首">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M18 5v14M6 6l10 6-10 6V6Z" />
          </svg>
        </button>
        <button id="music-list-toggle" class="icon-button" type="button" aria-label="展开歌单" aria-expanded="false">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 6h12M4 11h12M4 16h8M19 5v12a3 3 0 1 1-2-2.83" />
          </svg>
        </button>
      </div>

      <section id="music-lyrics" class="music-lyrics" aria-label="歌词" hidden>
        <div id="music-lyrics-content" class="music-lyrics-content">
          <p class="music-lyrics-empty">暂无歌词</p>
        </div>
      </section>
      <div id="music-status" class="music-status" aria-live="polite"></div>
      <ol id="music-playlist" class="music-playlist" hidden></ol>
      <a
        id="music-source"
        class="music-source"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
      >
        在 QQ 音乐中打开
      </a>
      <audio id="music-audio" preload="metadata"></audio>
    </aside>
  )
}

<script is:inline define:vars={{ config }}>
  (() => {
    if (window.__astroPaperMusicPlayer) return;
    window.__astroPaperMusicPlayer = true;

    const settings = JSON.parse(config);
    const player = document.querySelector("#music-player");
    if (!player) return;

    const audio = player.querySelector("#music-audio");
    const playerToggle = player.querySelector("#music-player-toggle");
    const cover = player.querySelector("#music-cover");
    const title = player.querySelector("#music-title");
    const artist = player.querySelector("#music-artist");
    const source = player.querySelector("#music-source");
    const play = player.querySelector("#music-play");
    const prev = player.querySelector("#music-prev");
    const next = player.querySelector("#music-next");
    const loop = player.querySelector("#music-loop");
    const mute = player.querySelector("#music-mute");
    const lyricsToggle = player.querySelector("#music-lyrics-toggle");
    const listToggle = player.querySelector("#music-list-toggle");
    const seek = player.querySelector("#music-seek");
    const volume = player.querySelector("#music-volume");
    const current = player.querySelector("#music-current");
    const duration = player.querySelector("#music-duration");
    const status = player.querySelector("#music-status");
    const lyricsElement = player.querySelector("#music-lyrics");
    const lyricsContent = player.querySelector("#music-lyrics-content");
    const playlistElement = player.querySelector("#music-playlist");

    let playlist = [];
    let currentIndex = 0;
    let lyricLines = [];
    let activeLyricIndex = -1;

    const setCollapsed = collapsed => {
      player.toggleAttribute("data-collapsed", collapsed);
      playerToggle.setAttribute("aria-expanded", String(!collapsed));
      playerToggle.setAttribute(
        "aria-label",
        collapsed ? "展开音乐播放器" : "收起音乐播放器"
      );
      localStorage.setItem("music-player-collapsed", String(collapsed));
    };

    const formatTime = seconds => {
      if (!Number.isFinite(seconds)) return "0:00";
      const minutes = Math.floor(seconds / 60);
      const remainder = Math.floor(seconds % 60);
      return `${minutes}:${String(remainder).padStart(2, "0")}`;
    };

    const resourceIds = Array.isArray(settings.id) ? settings.id : [settings.id];

    const qqUrl = (id = resourceIds[0]) => {
      const paths = {
        song: "songDetail",
        playlist: "playlist",
        album: "albumDetail",
        artist: "singer",
      };
      return `https://y.qq.com/n/ryqq_v2/${paths[settings.type]}/${id}`;
    };

    const apiUrl = (template, id) =>
      template
        .replace(":server", settings.server)
        .replace(":type", settings.type)
        .replace(":id", id)
        .replace(":r", String(Math.random()));

    const fetchLyrics = async lyrics => {
      if (!lyrics || !/^https?:\/\//i.test(lyrics)) return lyrics || "";
      try {
        const response = await fetch(lyrics);
        return response.ok ? await response.text() : "";
      } catch {
        return "";
      }
    };

    const updateRange = element => {
      const min = Number(element.min) || 0;
      const max = Number(element.max) || 100;
      const percentage = ((Number(element.value) - min) / (max - min)) * 100;
      element.style.setProperty("--range-progress", `${percentage}%`);
    };

    const parseLyrics = lyrics => {
      if (!lyrics) return [];
      return lyrics
        .split(/\r?\n/)
        .flatMap(line => {
          const text = line.replace(/\[(\d{1,3}):(\d{1,2}(?:\.\d+)?)\]/g, "").trim();
          if (!text) return [];
          return [...line.matchAll(/\[(\d{1,3}):(\d{1,2}(?:\.\d+)?)\]/g)].map(
            match => ({
              time: Number(match[1]) * 60 + Number(match[2]),
              text,
            })
          );
        })
        .sort((a, b) => a.time - b.time);
    };

    const renderLyrics = lyrics => {
      lyricLines = parseLyrics(lyrics);
      activeLyricIndex = -1;
      lyricsContent.replaceChildren();
      if (!lyricLines.length) {
        const empty = document.createElement("p");
        empty.className = "music-lyrics-empty";
        empty.textContent = "暂无歌词";
        lyricsContent.append(empty);
        return;
      }
      lyricLines.forEach(line => {
        const paragraph = document.createElement("p");
        paragraph.textContent = line.text;
        lyricsContent.append(paragraph);
      });
      lyricsContent.scrollTop = 0;
    };

    const updateLyrics = time => {
      if (!lyricLines.length) return;
      let nextIndex = -1;
      for (let index = lyricLines.length - 1; index >= 0; index -= 1) {
        if (time >= lyricLines[index].time) {
          nextIndex = index;
          break;
        }
      }
      if (nextIndex === activeLyricIndex) return;
      activeLyricIndex = nextIndex;
      lyricsContent.querySelectorAll("p").forEach((line, index) => {
        line.toggleAttribute("data-active", index === activeLyricIndex);
      });
      if (activeLyricIndex >= 0) {
        lyricsContent.children[activeLyricIndex]?.scrollIntoView({
          behavior: "smooth",
          block: "center",
        });
      }
    };

    const renderPlaylist = () => {
      playlistElement.replaceChildren();
      playlist.forEach((track, index) => {
        const item = document.createElement("li");
        const button = document.createElement("button");
        button.type = "button";
        button.textContent = `${track.name} · ${track.artist}`;
        button.addEventListener("click", () => loadTrack(index, true));
        item.append(button);
        playlistElement.append(item);
      });
    };

    const updateActiveTrack = () => {
      playlistElement.querySelectorAll("button").forEach((button, index) => {
        button.toggleAttribute("data-active", index === currentIndex);
      });
    };

    const loadTrack = (index, shouldPlay = false) => {
      if (!playlist.length) return;
      currentIndex = (index + playlist.length) % playlist.length;
      const track = playlist[currentIndex];
      audio.src = track.url;
      title.textContent = track.name;
      artist.textContent = track.artist;
      cover.hidden = !track.pic;
      if (track.pic) cover.src = track.pic;
      source.href = qqUrl(track.resourceId);
      renderLyrics(track.lrc);
      updateActiveTrack();
      if (shouldPlay) {
        audio.play().catch(() => {
          status.textContent = "浏览器阻止了播放，请再次点击播放。";
        });
      }
    };

    const fetchPlaylist = async () => {
      status.textContent = "正在加载 QQ 音乐...";
      const tracks = [];
      for (const resourceId of resourceIds) {
        for (const template of [settings.api, ...settings.fallbackApis]) {
          try {
            const response = await fetch(apiUrl(template, resourceId));
            if (!response.ok) continue;
            const data = await response.json();
            if (!Array.isArray(data) || !data.length) continue;
            const resourceTracks = await Promise.all(
              data.map(async item => ({
                  name: item.title || item.name || "未知歌曲",
                  artist: item.author || item.artist || "未知歌手",
                  url: item.url || "",
                  pic: item.pic || item.cover || "",
                  lrc: await fetchLyrics(item.lrc || item.lyric || ""),
                  resourceId,
                }))
            );
            tracks.push(...resourceTracks.filter(item => item.url));
            break;
          } catch {}
        }
      }
      playlist = tracks;
      if (playlist.length) {
        status.textContent = "";
        renderPlaylist();
        loadTrack(0);
        return;
      }
      title.textContent = "音乐加载失败";
      artist.textContent = "可前往 QQ 音乐播放";
      source.href = qqUrl();
      status.textContent = "Meting API 暂时不可用。";
    };

    play.addEventListener("click", () => {
      if (audio.paused) audio.play().catch(() => {});
      else audio.pause();
    });
    playerToggle.addEventListener("click", () => {
      setCollapsed(!player.hasAttribute("data-collapsed"));
    });
    prev.addEventListener("click", () => loadTrack(currentIndex - 1, true));
    next.addEventListener("click", () => loadTrack(currentIndex + 1, true));
    loop.addEventListener("click", () => {
      audio.loop = !audio.loop;
      loop.toggleAttribute("data-active", audio.loop);
    });
    mute.addEventListener("click", () => {
      audio.muted = !audio.muted;
      mute.toggleAttribute("data-muted", audio.muted);
    });
    lyricsToggle.addEventListener("click", () => {
      lyricsElement.hidden = !lyricsElement.hidden;
      lyricsToggle.toggleAttribute("data-active", !lyricsElement.hidden);
      lyricsToggle.setAttribute("aria-expanded", String(!lyricsElement.hidden));
      lyricsToggle.setAttribute("aria-label", lyricsElement.hidden ? "展开歌词" : "收起歌词");
      if (!lyricsElement.hidden) updateLyrics(audio.currentTime);
    });
    listToggle.addEventListener("click", () => {
      playlistElement.hidden = !playlistElement.hidden;
      listToggle.toggleAttribute("data-active", !playlistElement.hidden);
      listToggle.setAttribute("aria-expanded", String(!playlistElement.hidden));
      listToggle.setAttribute("aria-label", playlistElement.hidden ? "展开歌单" : "收起歌单");
    });
    volume.addEventListener("input", () => {
      audio.volume = Number(volume.value);
      audio.muted = false;
      mute.removeAttribute("data-muted");
      localStorage.setItem("music-volume", volume.value);
      updateRange(volume);
    });
    seek.addEventListener("input", () => {
      if (audio.duration) {
        audio.currentTime = (Number(seek.value) / 100) * audio.duration;
      }
      updateRange(seek);
    });
    audio.addEventListener("play", () => {
      player.toggleAttribute("data-playing", true);
      play.setAttribute("aria-label", "暂停");
    });
    audio.addEventListener("pause", () => {
      player.removeAttribute("data-playing");
      play.setAttribute("aria-label", "播放");
    });
    audio.addEventListener("ended", () => {
      if (!audio.loop) loadTrack(currentIndex + 1, true);
    });
    audio.addEventListener("timeupdate", () => {
      seek.value = audio.duration
        ? String((audio.currentTime / audio.duration) * 100)
        : "0";
      current.textContent = formatTime(audio.currentTime);
      duration.textContent = formatTime(audio.duration);
      updateRange(seek);
      updateLyrics(audio.currentTime);
    });
    audio.addEventListener("error", () => {
      status.textContent = "当前歌曲无法播放，请尝试下一首或前往 QQ 音乐。";
    });

    source.href = qqUrl();
    const savedCollapsed = localStorage.getItem("music-player-collapsed");
    setCollapsed(
      savedCollapsed === null
        ? window.matchMedia("(max-width: 640px)").matches
        : savedCollapsed === "true"
    );
    const savedVolume = localStorage.getItem("music-volume");
    audio.volume = savedVolume === null ? settings.volume : Number(savedVolume);
    volume.value = String(audio.volume);
    updateRange(volume);
    updateRange(seek);
    fetchPlaylist();
  })();
</script>

<style>
  .music-player {
    position: fixed;
    bottom: 1.25rem;
    left: 1.25rem;
    z-index: 50;
    width: min(21rem, calc(100vw - 2rem));
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    border-radius: 1.4rem;
    padding: 1.15rem 1.25rem 1rem;
    color: var(--foreground);
    background: color-mix(in srgb, var(--background) 92%, transparent);
    box-shadow: 0 12px 30px rgb(0 0 0 / 12%);
    font-size: 0.875rem;
    backdrop-filter: blur(18px);
    transition:
      width 180ms ease,
      padding 180ms ease,
      border-radius 180ms ease;
  }

  .music-player-toggle {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 2;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
  }

  .music-player-toggle .music-icon {
    display: none;
  }

  .music-player[data-collapsed] {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 999px;
    padding: 0;
  }

  .music-player[data-collapsed] > :not(.music-player-toggle, audio) {
    display: none;
  }

  .music-player[data-collapsed] .music-player-toggle {
    position: static;
    width: 100%;
    height: 100%;
    color: var(--accent);
  }

  .music-player[data-collapsed] .collapse-icon {
    display: none;
  }

  .music-player[data-collapsed] .music-icon {
    display: block;
    width: 1.5rem;
  }

  .music-header {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1rem;
    font-size: 1.25rem;
    padding-right: 2rem;
  }

  .music-header span {
    width: 0.25rem;
    height: 1.3rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .music-track {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .music-track img {
    width: 3.8rem;
    height: 3.8rem;
    flex: none;
    border: 2px solid var(--background);
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 4px 12px rgb(0 0 0 / 18%);
  }

  .music-player[data-playing] .music-track img {
    animation: cover-spin 12s linear infinite;
  }

  .music-meta {
    display: flex;
    min-width: 0;
    flex: 1;
    flex-direction: column;
    gap: 0.15rem;
  }

  .music-meta strong,
  .music-meta span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .music-meta strong {
    font-size: 1rem;
  }

  .music-meta span,
  .music-timeline,
  .music-status,
  .music-source {
    color: var(--muted-foreground);
    font-size: 0.75rem;
  }

  .music-timeline {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin: 0.45rem 0 0.2rem 4.55rem;
  }

  .music-timeline label {
    display: flex;
    min-width: 5rem;
    flex: 1;
    align-items: center;
    justify-content: flex-end;
    gap: 0.35rem;
  }

  .music-timeline svg {
    width: 1rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  input[type="range"] {
    height: 0.3rem;
    appearance: none;
    border-radius: 999px;
    background: linear-gradient(
      to right,
      var(--accent) var(--range-progress, 0%),
      color-mix(in srgb, var(--muted-foreground) 20%, transparent) var(--range-progress, 0%)
    );
    cursor: pointer;
  }

  input[type="range"]::-webkit-slider-thumb {
    width: 0.7rem;
    height: 0.7rem;
    appearance: none;
    border-radius: 999px;
    background: var(--accent);
    opacity: 0;
  }

  input[type="range"]:hover::-webkit-slider-thumb,
  input[type="range"]:focus-visible::-webkit-slider-thumb {
    opacity: 1;
  }

  #music-volume {
    width: 4.5rem;
  }

  .music-seek {
    width: 100%;
  }

  .music-controls {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    place-items: center;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 55%, transparent);
  }

  button {
    display: grid;
    place-items: center;
    border: 0;
    color: var(--muted-foreground);
    background: transparent;
  }

  button:hover,
  button[data-active] {
    color: var(--accent);
  }

  button svg {
    width: 1.35rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .play-button {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 999px;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }

  .play-button svg {
    width: 1.55rem;
  }

  .pause-icon,
  .volume-off,
  .music-player[data-playing] .play-icon,
  #music-mute[data-muted] .volume-on {
    display: none;
  }

  .music-player[data-playing] .pause-icon,
  #music-mute[data-muted] .volume-off {
    display: block;
  }

  .music-status {
    margin-top: 0.5rem;
    text-align: center;
  }

  .music-lyrics {
    margin-top: 0.85rem;
    border-top: 1px solid color-mix(in srgb, var(--border) 55%, transparent);
    padding-top: 0.75rem;
  }

  .music-lyrics-content {
    height: 12rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-color: color-mix(in srgb, var(--muted-foreground) 45%, transparent) transparent;
    scrollbar-width: thin;
    text-align: center;
    mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);
  }

  .music-lyrics-content p {
    margin: 0;
    padding: 0.4rem 0.25rem;
    color: var(--muted-foreground);
    font-size: 0.82rem;
    line-height: 1.5;
    opacity: 0.55;
    transition:
      color 180ms ease,
      opacity 180ms ease,
      transform 180ms ease;
  }

  .music-lyrics-content p[data-active] {
    color: var(--accent);
    font-weight: 600;
    opacity: 1;
    transform: scale(1.04);
  }

  .music-lyrics-content .music-lyrics-empty {
    display: grid;
    height: 100%;
    place-items: center;
    padding: 0;
    font-size: 0.9rem;
    opacity: 0.65;
  }

  .music-playlist {
    max-height: 9rem;
    margin-top: 0.75rem;
    overflow-y: auto;
    border-top: 1px solid color-mix(in srgb, var(--border) 55%, transparent);
    padding-top: 0.5rem;
  }

  .music-playlist li {
    list-style: none;
  }

  .music-playlist button {
    width: 100%;
    overflow: hidden;
    padding: 0.35rem;
    text-align: left;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .music-source {
    display: none;
    margin-top: 0.5rem;
    text-align: center;
  }

  .music-status:not(:empty) + .music-playlist + .music-source {
    display: block;
