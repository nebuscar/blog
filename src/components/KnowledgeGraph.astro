---
type GraphNode = {
  id: string;
  title: string;
  url: string;
  tags: string[];
};

type GraphLink = {
  source: string;
  target: string;
};

type Props = {
  graph: {
    nodes: GraphNode[];
    links: GraphLink[];
  };
  currentId?: string;
  compact?: boolean;
  sidebar?: boolean;
  title?: string;
  collapsible?: boolean;
  fullPage?: boolean;
};

const {
  graph,
  currentId,
  compact = false,
  sidebar = false,
  title = "关联文档图谱",
  collapsible = false,
  fullPage = false,
} = Astro.props;

const graphJson = JSON.stringify({ ...graph, currentId }).replace(
  /</g,
  "\\u003c"
);
const graphTags = [...new Set(graph.nodes.flatMap(node => node.tags))].sort(
  (first, second) => first.localeCompare(second, "zh-CN")
);
---

{
  graph.nodes.length > 0 && (
    <section
      class:list={[
        "knowledge-graph-shell",
        {
          "knowledge-graph-compact": compact,
          "knowledge-graph-sidebar": sidebar,
          "knowledge-graph-full-page": fullPage,
        },
      ]}
      data-knowledge-graph
      data-collapsible={String(collapsible)}
    >
      <details class="knowledge-graph-details" open={!collapsible}>
        <summary>
          <span>{title}</span>
          <span class="knowledge-graph-count">
            {graph.nodes.length} 篇文档 · {graph.links.length} 条关联
          </span>
        </summary>

        <div class="knowledge-graph-toolbar">
          {!sidebar && (
            <label>
              <span class="sr-only">搜索图谱中的文章</span>
              <input
                type="search"
                placeholder="搜索文章"
                data-graph-search
                autocomplete="off"
              />
            </label>
          )}
          <button type="button" data-graph-reset>
            重置视图
          </button>
          {!compact && (
            <button
              type="button"
              data-graph-settings-toggle
              aria-expanded="false"
              aria-controls="knowledge-graph-settings"
            >
              图谱设置
            </button>
          )}
          {compact && (
            <a href="/graph/" class="knowledge-graph-full-link">
              查看全站图谱
            </a>
          )}
        </div>

        {!compact && (
          <aside
            id="knowledge-graph-settings"
            class="knowledge-graph-settings"
            data-graph-settings-panel
            hidden
          >
            <header>
              <strong>图谱设置</strong>
              <div>
                <button type="button" data-graph-settings-reset>
                  恢复默认
                </button>
                <button
                  type="button"
                  data-graph-settings-close
                  aria-label="关闭设置"
                >
                  ×
                </button>
              </div>
            </header>

            <details open>
              <summary>筛选</summary>
              <label class="graph-switch">
                <span>显示孤立文章</span>
                <input type="checkbox" data-graph-show-orphans checked />
              </label>
              {graphTags.length > 0 && (
                <fieldset class="graph-tag-filter" data-graph-tag-filter>
                  <legend>标签</legend>
                  {graphTags.map(tag => (
                    <label>
                      <input type="checkbox" value={tag} />
                      <span>{tag}</span>
                    </label>
                  ))}
                </fieldset>
              )}
            </details>

            <details open>
              <summary>外观</summary>
              <label class="graph-range">
                <span>标题透明度</span>
                <input
                  type="range"
                  min="0"
                  max="1"
                  step="0.05"
                  value="0"
                  data-graph-label-opacity
                />
              </label>
              <label class="graph-range">
                <span>节点大小</span>
                <input
                  type="range"
                  min="0.5"
                  max="2"
                  step="0.1"
                  value="1"
                  data-graph-node-size
                />
              </label>
              <label class="graph-range">
                <span>连线粗细</span>
                <input
                  type="range"
                  min="0.5"
                  max="4"
                  step="0.25"
                  value="1"
                  data-graph-link-width
                />
              </label>
              <button type="button" data-graph-animation>
                暂停动画
              </button>
            </details>

            <details open>
              <summary>力度</summary>
              <label class="graph-range">
                <span>图谱向心力</span>
                <input
                  type="range"
                  min="0"
                  max="2"
                  step="0.1"
                  value="1"
                  data-graph-center-force
                />
              </label>
              <label class="graph-range">
                <span>节点排斥力</span>
                <input
                  type="range"
                  min="0.25"
                  max="2"
                  step="0.05"
                  value="1"
                  data-graph-repel-force
                />
              </label>
              <label class="graph-range">
                <span>关联吸引力</span>
                <input
                  type="range"
                  min="0"
                  max="1"
                  step="0.05"
                  value="1"
                  data-graph-link-force
                />
              </label>
            </details>
          </aside>
        )}

        <div
          class="knowledge-graph-canvas"
          data-graph-canvas
          role="application"
          aria-label={`${title}，可拖动节点、滚轮缩放，点击节点打开文章`}
        >
          <svg aria-hidden="true">
            <g data-graph-viewport>
              <g data-graph-links />
              <g data-graph-nodes />
            </g>
          </svg>
          <p class="knowledge-graph-hint">
            拖动节点 · 滚轮缩放 · 点击节点打开文章
          </p>
        </div>

        <script
          type="application/json"
          data-graph-data
          is:inline
          set:html={graphJson}
        />
      </details>
    </section>
  )
}

<script>
  import { getConnectedNodeIds } from "@/utils/knowledgeGraphInteraction.mjs";
  import {
    DEFAULT_GRAPH_SETTINGS,
    filterGraphNodes,
    normalizeGraphSettings,
  } from "@/utils/knowledgeGraphSettings.mjs";

  type GraphNode = {
    id: string;
    title: string;
    url: string;
    tags: string[];
    x: number;
    y: number;
    vx: number;
    vy: number;
    degree: number;
  };

  type GraphLink = {
    source: string;
    target: string;
  };

  type GraphPayload = {
    nodes: Omit<GraphNode, "x" | "y" | "vx" | "vy" | "degree">[];
    links: GraphLink[];
    currentId?: string;
  };

  type GraphSettings = {
    labelOpacity: number;
    nodeSize: number;
    linkWidth: number;
    centerForce: number;
    repelForce: number;
    linkForce: number;
    showOrphans: boolean;
    selectedTags: string[];
    animation: boolean;
  };

  const svgNamespace = "http://www.w3.org/2000/svg";

  function hash(value: string) {
    let result = 2166136261;
    for (const character of value) {
      result ^= character.codePointAt(0) ?? 0;
      result = Math.imul(result, 16777619);
    }
    return result >>> 0;
  }

  function setupKnowledgeGraph(root: HTMLElement) {
    if (root.dataset.graphReady === "true") return;

    const dataElement = root.querySelector<HTMLElement>("[data-graph-data]");
    const canvas = root.querySelector<HTMLElement>("[data-graph-canvas]");
    const svg = canvas?.querySelector<SVGSVGElement>("svg");
    const viewport = svg?.querySelector<SVGGElement>("[data-graph-viewport]");
    const linksLayer = svg?.querySelector<SVGGElement>("[data-graph-links]");
    const nodesLayer = svg?.querySelector<SVGGElement>("[data-graph-nodes]");
    const search = root.querySelector<HTMLInputElement>("[data-graph-search]");
    const reset = root.querySelector<HTMLButtonElement>("[data-graph-reset]");
    const settingsToggle = root.querySelector<HTMLButtonElement>(
      "[data-graph-settings-toggle]"
    );
    const settingsPanel = root.querySelector<HTMLElement>(
      "[data-graph-settings-panel]"
    );
    const settingsClose = root.querySelector<HTMLButtonElement>(
      "[data-graph-settings-close]"
    );
    const settingsReset = root.querySelector<HTMLButtonElement>(
      "[data-graph-settings-reset]"
    );
    const showOrphans = root.querySelector<HTMLInputElement>(
      "[data-graph-show-orphans]"
    );
    const tagFilter = root.querySelector<HTMLElement>(
      "[data-graph-tag-filter]"
    );
    const labelOpacity = root.querySelector<HTMLInputElement>(
      "[data-graph-label-opacity]"
    );
    const nodeSize = root.querySelector<HTMLInputElement>(
      "[data-graph-node-size]"
    );
    const linkWidth = root.querySelector<HTMLInputElement>(
      "[data-graph-link-width]"
    );
    const animationToggle = root.querySelector<HTMLButtonElement>(
      "[data-graph-animation]"
    );
    const centerForce = root.querySelector<HTMLInputElement>(
      "[data-graph-center-force]"
    );
    const repelForce = root.querySelector<HTMLInputElement>(
      "[data-graph-repel-force]"
    );
    const linkForce = root.querySelector<HTMLInputElement>(
      "[data-graph-link-force]"
    );
    const details = root.querySelector<HTMLDetailsElement>(
      ".knowledge-graph-details"
    );

    if (
      !dataElement ||
      !canvas ||
      !svg ||
      !viewport ||
      !linksLayer ||
      !nodesLayer
    ) {
      return;
    }

    const payload = JSON.parse(dataElement.textContent ?? "{}") as GraphPayload;
    if (!payload.nodes?.length) return;

    root.dataset.graphReady = "true";
    const expandedViewport = root.classList.contains("knowledge-graph-sidebar")
      ? "(min-width: 1280px)"
      : "(min-width: 640px)";
    if (
      root.dataset.collapsible === "true" &&
      window.matchMedia(expandedViewport).matches
    ) {
      details?.setAttribute("open", "");
    }

    const width = Math.max(canvas.clientWidth, 320);
    const height = Math.max(canvas.clientHeight, 320);
    const nodeById = new Map<string, GraphNode>();
    const nodes = payload.nodes.map((node, index) => {
      const angle = (index / payload.nodes.length) * Math.PI * 2;
      const jitter = (hash(node.id) % 70) - 35;
      const graphNode: GraphNode = {
        ...node,
        x: width / 2 + Math.cos(angle) * (width * 0.25) + jitter,
        y: height / 2 + Math.sin(angle) * (height * 0.25) + jitter,
        vx: 0,
        vy: 0,
        degree: 0,
      };
      nodeById.set(node.id, graphNode);
      return graphNode;
    });
    const links = payload.links.filter(
      link => nodeById.has(link.source) && nodeById.has(link.target)
    );

    for (const link of links) {
      nodeById.get(link.source)!.degree += 1;
      nodeById.get(link.target)!.degree += 1;
    }

    const linkElements = links.map(link => {
      const line = document.createElementNS(svgNamespace, "line");
      line.classList.add("knowledge-graph-link");
      line.dataset.source = link.source;
      line.dataset.target = link.target;
      linksLayer.append(line);
      return { link, line };
    });

    const nodeElements = nodes.map(node => {
      const group = document.createElementNS(svgNamespace, "g");
      const circle = document.createElementNS(svgNamespace, "circle");
      const label = document.createElementNS(svgNamespace, "text");
      const radius =
        node.id === payload.currentId ? 12 : Math.min(10, 6 + node.degree);

      group.classList.add("knowledge-graph-node");
      group.dataset.nodeId = node.id;
      group.setAttribute("role", "link");
      group.setAttribute("tabindex", "0");
      group.setAttribute("aria-label", `打开文章：${node.title}`);
      if (node.id === payload.currentId) group.dataset.current = "true";

      circle.setAttribute("r", String(radius));
      label.setAttribute("x", String(radius + 5));
      label.setAttribute("y", "4");
      label.textContent = node.title;
      if (
        root.classList.contains("knowledge-graph-sidebar") &&
        node.id === payload.currentId
      ) {
        group.dataset.labelVisible = "true";
      }
      group.append(circle, label);
      nodesLayer.append(group);

      return { node, group, circle, label, radius };
    });

    let scale = 1;
    let translateX = 0;
    let translateY = 0;
    let animationFrame = 0;
    let ticks = 0;
    let draggedNode: GraphNode | null = null;
    let dragStartX = 0;
    let dragStartY = 0;
    let draggedDistance = 0;
    let panning = false;
    let panStartX = 0;
    let panStartY = 0;
    let panOriginX = 0;
    let panOriginY = 0;
    const settingsStorageKey = "knowledge-graph-settings";
    let settings: GraphSettings = {
      ...DEFAULT_GRAPH_SETTINGS,
      selectedTags: [],
    };
    let visibleNodeIds = new Set(nodes.map(node => node.id));
    let animationPlaying = true;
    const availableTags = new Set(nodes.flatMap(node => node.tags.map(String)));

    const applyViewport = () => {
      viewport.setAttribute(
        "transform",
        `translate(${translateX} ${translateY}) scale(${scale})`
      );
    };

    const render = () => {
      for (const { link, line } of linkElements) {
        const source = nodeById.get(link.source)!;
        const target = nodeById.get(link.target)!;
        const visible =
          visibleNodeIds.has(link.source) && visibleNodeIds.has(link.target);
        line.toggleAttribute("hidden", !visible);
        if (!visible) continue;
        line.setAttribute("x1", String(source.x));
        line.setAttribute("y1", String(source.y));
        line.setAttribute("x2", String(target.x));
        line.setAttribute("y2", String(target.y));
      }

      for (const { node, group } of nodeElements) {
        group.toggleAttribute("hidden", !visibleNodeIds.has(node.id));
        if (!visibleNodeIds.has(node.id)) continue;
        group.setAttribute("transform", `translate(${node.x} ${node.y})`);
      }
    };

    const tick = () => {
      ticks += 1;

      for (let i = 0; i < nodes.length; i += 1) {
        for (let j = i + 1; j < nodes.length; j += 1) {
          const first = nodes[i];
          const second = nodes[j];
          let dx = second.x - first.x;
          let dy = second.y - first.y;
          const distanceSquared = Math.max(dx * dx + dy * dy, 80);
          const distance = Math.sqrt(distanceSquared);
          const force = (850 * settings.repelForce) / distanceSquared;
          dx /= distance;
          dy /= distance;
          first.vx -= dx * force;
          first.vy -= dy * force;
          second.vx += dx * force;
          second.vy += dy * force;
        }
      }

      for (const link of links) {
        const source = nodeById.get(link.source)!;
        const target = nodeById.get(link.target)!;
        const dx = target.x - source.x;
        const dy = target.y - source.y;
        const distance = Math.max(Math.hypot(dx, dy), 1);
        const targetDistance = root.classList.contains(
          "knowledge-graph-compact"
        )
          ? 105
          : 135;
        const force = (distance - targetDistance) * 0.0018 * settings.linkForce;
        source.vx += (dx / distance) * force;
        source.vy += (dy / distance) * force;
        target.vx -= (dx / distance) * force;
        target.vy -= (dy / distance) * force;
      }

      for (const node of nodes) {
        if (node === draggedNode) continue;
        node.vx += (width / 2 - node.x) * 0.0007 * settings.centerForce;
        node.vy += (height / 2 - node.y) * 0.0007 * settings.centerForce;
        node.vx *= 0.9;
        node.vy *= 0.9;
        node.x = Math.min(width - 30, Math.max(30, node.x + node.vx));
        node.y = Math.min(height - 25, Math.max(25, node.y + node.vy));
      }

      render();
      if (animationPlaying && (ticks < 420 || draggedNode))
        animationFrame = requestAnimationFrame(tick);
    };

    const restart = () => {
      cancelAnimationFrame(animationFrame);
      ticks = 0;
      if (animationPlaying) animationFrame = requestAnimationFrame(tick);
    };

    const getSelectedTags = () =>
      Array.from(
        tagFilter?.querySelectorAll<HTMLInputElement>(
          'input[type="checkbox"]:checked'
        ) ?? []
      ).map(input => input.value);

    const updateFilters = () => {
      visibleNodeIds = filterGraphNodes(nodes, {
        query: search?.value ?? "",
        selectedTags: settings.selectedTags,
        showOrphans: settings.showOrphans,
      });
      render();
    };

    const applySettings = (nextSettings: Partial<GraphSettings>) => {
      settings = normalizeGraphSettings(
        nextSettings,
        availableTags
      ) as GraphSettings;
      animationPlaying = settings.animation;
      root.style.setProperty(
        "--graph-label-opacity",
        String(settings.labelOpacity)
      );
      root.style.setProperty("--graph-node-scale", String(settings.nodeSize));
      root.style.setProperty("--graph-link-width", String(settings.linkWidth));

      showOrphans && (showOrphans.checked = settings.showOrphans);
      labelOpacity && (labelOpacity.value = String(settings.labelOpacity));
      nodeSize && (nodeSize.value = String(settings.nodeSize));
      linkWidth && (linkWidth.value = String(settings.linkWidth));
      centerForce && (centerForce.value = String(settings.centerForce));
      repelForce && (repelForce.value = String(settings.repelForce));
      linkForce && (linkForce.value = String(settings.linkForce));
      animationToggle &&
        (animationToggle.textContent = animationPlaying
          ? "暂停动画"
          : "播放动画");
      tagFilter
        ?.querySelectorAll<HTMLInputElement>('input[type="checkbox"]')
        .forEach(
          input => (input.checked = settings.selectedTags.includes(input.value))
        );

      for (const { circle, label, radius } of nodeElements) {
        circle.setAttribute("r", String(radius * settings.nodeSize));
        label.setAttribute("x", String(radius * settings.nodeSize + 5));
      }
      updateFilters();
      animationPlaying ? restart() : cancelAnimationFrame(animationFrame);
    };

    const persistSettings = () => {
      localStorage.setItem(settingsStorageKey, JSON.stringify(settings));
    };

    const updateSetting = (patch: Partial<GraphSettings>) => {
      applySettings({ ...settings, ...patch });
      persistSettings();
    };

    const clientToGraph = (clientX: number, clientY: number) => {
      const bounds = svg.getBoundingClientRect();
      return {
        x: (clientX - bounds.left - translateX) / scale,
        y: (clientY - bounds.top - translateY) / scale,
      };
    };

    const openNode = (node: GraphNode) => {
      window.location.href = node.url;
    };

    const clearFocus = () => {
      delete root.dataset.highlightNode;

      for (const { group } of nodeElements) {
        group.removeAttribute("data-focused");
        group.removeAttribute("data-related");
        group.removeAttribute("data-focus-dim");
        group.toggleAttribute(
          "data-label-visible",
          root.classList.contains("knowledge-graph-sidebar") &&
            group.dataset.nodeId === payload.currentId
        );
      }

      for (const { line } of linkElements) {
        line.removeAttribute("data-highlight");
        line.removeAttribute("data-focus-dim");
      }
    };

    const focusNode = (node: GraphNode) => {
      root.dataset.highlightNode = node.id;
      const connectedIds = getConnectedNodeIds(links, node.id);

      for (const { node: candidate, group } of nodeElements) {
        group.toggleAttribute("data-focused", candidate.id === node.id);
        group.toggleAttribute(
          "data-related",
          candidate.id !== node.id && connectedIds.has(candidate.id)
        );
        group.toggleAttribute(
          "data-focus-dim",
          !connectedIds.has(candidate.id)
        );
        group.toggleAttribute("data-label-visible", candidate.id === node.id);
      }

      for (const { link, line } of linkElements) {
        const highlighted = link.source === node.id || link.target === node.id;
        line.toggleAttribute("data-highlight", highlighted);
        line.toggleAttribute("data-focus-dim", !highlighted);
      }
    };

    for (const { node, group } of nodeElements) {
      group.addEventListener("pointerdown", event => {
        event.preventDefault();
        event.stopPropagation();
        draggedNode = node;
        draggedDistance = 0;
        dragStartX = event.clientX;
        dragStartY = event.clientY;
        group.setPointerCapture(event.pointerId);
        restart();
      });

      group.addEventListener("pointermove", event => {
        if (draggedNode !== node) return;
        const point = clientToGraph(event.clientX, event.clientY);
        draggedDistance = Math.max(
          draggedDistance,
          Math.hypot(event.clientX - dragStartX, event.clientY - dragStartY)
        );
        node.x = point.x;
        node.y = point.y;
        node.vx = 0;
        node.vy = 0;
        render();
      });

      group.addEventListener("pointerup", event => {
        if (draggedNode !== node) return;
        group.releasePointerCapture(event.pointerId);
        draggedNode = null;
        if (draggedDistance < 5) openNode(node);
      });

      group.addEventListener("keydown", event => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          openNode(node);
        }
      });

      group.addEventListener("mouseenter", () => focusNode(node));
      group.addEventListener("mouseleave", clearFocus);
      group.addEventListener("focus", () => focusNode(node));
      group.addEventListener("blur", clearFocus);
    }

    svg.addEventListener(
      "wheel",
      event => {
        event.preventDefault();
        const previousScale = scale;
        scale = Math.min(
          2.4,
          Math.max(0.45, scale * (event.deltaY > 0 ? 0.9 : 1.1))
        );
        const bounds = svg.getBoundingClientRect();
        const pointerX = event.clientX - bounds.left;
        const pointerY = event.clientY - bounds.top;
        translateX =
          pointerX - ((pointerX - translateX) / previousScale) * scale;
        translateY =
          pointerY - ((pointerY - translateY) / previousScale) * scale;
        applyViewport();
      },
      { passive: false }
    );

    svg.addEventListener("pointerdown", event => {
      if ((event.target as Element).closest(".knowledge-graph-node")) return;
      panning = true;
      panStartX = event.clientX;
      panStartY = event.clientY;
      panOriginX = translateX;
      panOriginY = translateY;
      svg.setPointerCapture(event.pointerId);
    });

    svg.addEventListener("pointermove", event => {
      if (!panning) return;
      translateX = panOriginX + event.clientX - panStartX;
      translateY = panOriginY + event.clientY - panStartY;
      applyViewport();
    });

    svg.addEventListener("pointerup", event => {
      if (!panning) return;
      panning = false;
      svg.releasePointerCapture(event.pointerId);
    });

    search?.addEventListener("input", () => {
      const query = search.value.trim().toLocaleLowerCase();
      for (const { node, group } of nodeElements) {
        group.toggleAttribute(
          "data-search-match",
          Boolean(query && node.title.toLocaleLowerCase().includes(query))
        );
      }
      updateFilters();
    });

    settingsToggle?.addEventListener("click", () => {
      if (!settingsPanel) return;
      settingsPanel.hidden = !settingsPanel.hidden;
      root.toggleAttribute("data-settings-open", !settingsPanel.hidden);
      settingsToggle.setAttribute(
        "aria-expanded",
        String(!settingsPanel.hidden)
      );
    });

    settingsClose?.addEventListener("click", () => {
      if (!settingsPanel) return;
      settingsPanel.hidden = true;
      root.removeAttribute("data-settings-open");
      settingsToggle?.setAttribute("aria-expanded", "false");
    });

    showOrphans?.addEventListener("change", () =>
      updateSetting({ showOrphans: showOrphans.checked })
    );
    tagFilter?.addEventListener("change", () =>
      updateSetting({ selectedTags: getSelectedTags() })
    );
    labelOpacity?.addEventListener("input", () =>
      updateSetting({ labelOpacity: Number(labelOpacity.value) })
    );
    nodeSize?.addEventListener("input", () =>
      updateSetting({ nodeSize: Number(nodeSize.value) })
    );
    linkWidth?.addEventListener("input", () =>
      updateSetting({ linkWidth: Number(linkWidth.value) })
    );
    centerForce?.addEventListener("input", () =>
      updateSetting({ centerForce: Number(centerForce.value) })
    );
    repelForce?.addEventListener("input", () =>
      updateSetting({ repelForce: Number(repelForce.value) })
    );
    linkForce?.addEventListener("input", () =>
      updateSetting({ linkForce: Number(linkForce.value) })
    );
    animationToggle?.addEventListener("click", () =>
      updateSetting({ animation: !animationPlaying })
    );
    settingsReset?.addEventListener("click", () => {
      localStorage.removeItem(settingsStorageKey);
      applySettings({ ...DEFAULT_GRAPH_SETTINGS });
    });

    reset?.addEventListener("click", () => {
      scale = 1;
      translateX = 0;
      translateY = 0;
      applyViewport();
      restart();
    });

    details?.addEventListener("toggle", () => {
      if (details.open) {
        requestAnimationFrame(() => {
          render();
          restart();
        });
      }
    });

    if (settingsPanel) {
      try {
        const stored = JSON.parse(
          localStorage.getItem(settingsStorageKey) ?? "null"
        );
        applySettings(stored ?? { ...DEFAULT_GRAPH_SETTINGS });
      } catch {
        localStorage.removeItem(settingsStorageKey);
        applySettings({ ...DEFAULT_GRAPH_SETTINGS });
      }
    }

    render();
    applyViewport();
    if (!settingsPanel) restart();
  }

  function setupKnowledgeGraphs() {
    document
      .querySelectorAll<HTMLElement>("[data-knowledge-graph]")
      .forEach(setupKnowledgeGraph);
  }

  setupKnowledgeGraphs();
  document.addEventListener("astro:page-load", setupKnowledgeGraphs);
</script>

