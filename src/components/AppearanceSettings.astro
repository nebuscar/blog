---
import { backgroundWallpaper } from "@/config/backgroundWallpaper";

const config = JSON.stringify(backgroundWallpaper);

const modes = [
  { value: "banner", label: "横幅壁纸", icon: "▣" },
  { value: "fullscreen", label: "全屏壁纸", icon: "▤" },
  { value: "none", label: "纯色背景", icon: "□" },
];
---

<button
  id="appearance-toggle"
  class="appearance-toggle"
  type="button"
  aria-label="打开外观设置"
  aria-expanded="false"
>
  <svg viewBox="0 0 24 24" aria-hidden="true">
    <path
      d="M12 3a9 9 0 1 0 9 9c0-1.1-.9-2-2-2h-1.1a2 2 0 0 1-1.8-2.9l.5-1A2 2 0 0 0 14.8 3H12Z"
    ></path>
    <circle cx="7.5" cy="11.5" r=".8"></circle>
    <circle cx="10" cy="7.5" r=".8"></circle>
    <circle cx="15" cy="7" r=".8"></circle>
    <circle cx="7.8" cy="15.5" r=".8"></circle>
  </svg>
</button>

<aside
  id="appearance-panel"
  class="appearance-panel"
  aria-label="外观设置"
  hidden
>
  <div class="appearance-panel-header">
    <strong>外观设置</strong>
    <button id="appearance-close" type="button" aria-label="关闭外观设置"
      >×</button
    >
  </div>

  <section>
    <div class="setting-title">
      <span></span>
      <strong>主题色相</strong>
      <output id="hue-value">{backgroundWallpaper.defaultHue}</output>
    </div>
    <input
      id="hue-slider"
      class="hue-slider"
      type="range"
      min="0"
      max="360"
      value={backgroundWallpaper.defaultHue}
      aria-label="主题色相"
    />
  </section>

  <section>
    <div class="setting-title">
      <span></span>
      <strong>壁纸模式</strong>
    </div>
    <div class="wallpaper-modes">
      {
        modes.map(mode => (
          <button type="button" data-wallpaper-mode={mode.value}>
            <b aria-hidden="true">{mode.icon}</b>
            <span>{mode.label}</span>
          </button>
        ))
      }
    </div>
  </section>

  <button id="wallpaper-refresh" class="wallpaper-refresh" type="button">
    更换随机壁纸
  </button>
</aside>

<script is:inline define:vars={{ config }}>
  (() => {
    const settings = JSON.parse(config);
    const root = document.documentElement;
    const wallpaper = document.querySelector("#site-wallpaper");
    const toggle = document.querySelector("#appearance-toggle");
    const panel = document.querySelector("#appearance-panel");
    const close = document.querySelector("#appearance-close");
    const hueSlider = document.querySelector("#hue-slider");
    const hueValue = document.querySelector("#hue-value");
    const refresh = document.querySelector("#wallpaper-refresh");
    const modeButtons = panel.querySelectorAll("[data-wallpaper-mode]");

    const wallpaperUrl = () => {
      const source = window.matchMedia("(max-width: 640px)").matches
        ? settings.mobile
        : settings.desktop;
      return `${source}${source.includes("?") ? "&" : "?"}r=${Date.now()}`;
    };

    const applyWallpaper = (forceRefresh = false) => {
      if (!wallpaper) return;
      if (forceRefresh || !sessionStorage.getItem("wallpaper-url")) {
        sessionStorage.setItem("wallpaper-url", wallpaperUrl());
      }
      wallpaper.removeAttribute("data-loaded");
      const image = new Image();
      image.decoding = "async";
      image.fetchPriority = "high";
      image.onload = () => {
        wallpaper.style.backgroundImage = `url("${image.src}")`;
        wallpaper.toggleAttribute("data-loaded", true);
      };
      image.onerror = () => wallpaper.toggleAttribute("data-loaded", true);
      image.src = sessionStorage.getItem("wallpaper-url");
    };

    const applyMode = mode => {
      if (mode === "overlay") mode = "fullscreen";
      root.dataset.wallpaperMode = mode;
      localStorage.setItem("wallpaper-mode", mode);
      modeButtons.forEach(button => {
        button.toggleAttribute(
          "data-active",
          button.dataset.wallpaperMode === mode
        );
      });
      if (mode !== "none") applyWallpaper();
    };

    const applyHue = hue => {
      root.style.setProperty("--user-hue", hue);
      hueSlider.value = hue;
      hueValue.value = hue;
      hueValue.textContent = hue;
      localStorage.setItem("theme-hue", hue);
    };

    const setPanel = open => {
      panel.hidden = !open;
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "关闭外观设置" : "打开外观设置");
    };

    toggle.addEventListener("click", () => setPanel(panel.hidden));
    close.addEventListener("click", () => setPanel(false));
    hueSlider.addEventListener("input", () => applyHue(hueSlider.value));
    refresh.addEventListener("click", () => applyWallpaper(true));
    modeButtons.forEach(button => {
      button.addEventListener("click", () =>
        applyMode(button.dataset.wallpaperMode)
      );
    });

    applyHue(localStorage.getItem("theme-hue") || String(settings.defaultHue));
    applyMode(localStorage.getItem("wallpaper-mode") || settings.defaultMode);
  })();
</script>

<style>
  .appearance-toggle {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    display: grid;
    width: 3rem;
    height: 3rem;
    place-items: center;
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    border-radius: 999px;
    color: var(--accent);
    background: color-mix(in srgb, var(--background) 90%, transparent);
    box-shadow: 0 8px 24px rgb(0 0 0 / 15%);
    backdrop-filter: blur(16px);
  }

  .appearance-toggle svg,
  .appearance-panel-header button {
    width: 1.5rem;
  }

  .appearance-toggle svg {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .appearance-panel {
    position: fixed;
    right: 1rem;
    bottom: 4.75rem;
    z-index: 60;
    width: min(22rem, calc(100vw - 2rem));
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    border-radius: 1.2rem;
    padding: 1rem;
    color: var(--foreground);
    background: color-mix(in srgb, var(--background) 92%, transparent);
    box-shadow: 0 12px 30px rgb(0 0 0 / 18%);
    backdrop-filter: blur(20px);
  }

  .appearance-panel-header,
  .setting-title {
    display: flex;
    align-items: center;
  }

  .appearance-panel-header {
    justify-content: space-between;
    margin-bottom: 0.75rem;
    font-size: 1.05rem;
  }

  .appearance-panel-header button {
    border: 0;
    color: var(--muted-foreground);
    background: transparent;
    font-size: 1.5rem;
  }

  .appearance-panel section + section {
    margin-top: 1rem;
  }

  .setting-title {
    gap: 0.45rem;
    margin-bottom: 0.55rem;
  }

  .setting-title > span {
    width: 0.22rem;
    height: 1rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .setting-title output {
    margin-left: auto;
    border-radius: 0.35rem;
    padding: 0.1rem 0.45rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    font-size: 0.75rem;
  }

  .hue-slider {
    width: 100%;
    height: 0.75rem;
    appearance: none;
    border-radius: 999px;
    background: linear-gradient(
      to right,
      hsl(0 80% 70%),
      hsl(60 80% 70%),
      hsl(120 70% 65%),
      hsl(180 70% 65%),
      hsl(240 80% 75%),
      hsl(300 75% 75%),
      hsl(360 80% 70%)
    );
  }

  .hue-slider::-webkit-slider-thumb {
    width: 0.75rem;
    height: 1.1rem;
    appearance: none;
    border: 2px solid white;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 1px 4px rgb(0 0 0 / 25%);
  }

  .wallpaper-modes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .wallpaper-modes button,
  .wallpaper-refresh {
    border: 1px solid transparent;
    border-radius: 0.55rem;
    color: var(--muted-foreground);
    background: color-mix(in srgb, var(--accent) 7%, var(--background));
  }

  .wallpaper-modes button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.6rem 0.35rem;
    font-size: 0.78rem;
  }

  .wallpaper-modes button:hover,
  .wallpaper-modes button[data-active] {
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 16%, var(--background));
  }

  .wallpaper-refresh {
    width: 100%;
    margin-top: 0.75rem;
    padding: 0.5rem;
    font-size: 0.78rem;
  }

  @media (max-width: 640px) {
    .appearance-toggle {
      right: 0.75rem;
      bottom: 0.75rem;
      width: 2.75rem;
      height: 2.75rem;
    }

    .appearance-panel {
      right: 0.75rem;
      bottom: 4.1rem;
      width: calc(100vw - 1.5rem);
      max-height: calc(100dvh - 5rem);
      overflow-y: auto;
    }
  }
</style>
