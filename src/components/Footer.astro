---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";
import VisitorStats from "./VisitorStats.astro";
import { useTranslations } from "@/i18n";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const t = useTranslations(Astro.currentLocale);
const currentYear = new Date().getFullYear();

const technologyBadges = [
  {
    label: "Markdown 编辑器",
    value: "Obsidian",
    href: "https://obsidian.md/",
    color: "#7c3aed",
  },
  {
    label: "博客框架",
    value: "Astro",
    href: "https://astro.build/",
    color: "#f97316",
  },
  {
    label: "参考主题",
    value: "AstroPaper",
    href: "https://github.com/satnaing/astro-paper",
    color: "#0ea5e9",
  },
  {
    label: "代码托管",
    value: "GitHub",
    href: "https://github.com/nebuscar/blog",
    color: "#24292f",
  },
  {
    label: "网站托管",
    value: "Cloudflare Pages",
    href: "https://pages.cloudflare.com/",
    color: "#f48120",
  },
];
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="border-border flex flex-col items-center gap-3 border-t py-6">
    <Socials />
    <div class="flex flex-col items-center whitespace-nowrap sm:flex-row">
      <span>{t.footer.copyright} &#169; {currentYear}</span>
      <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
      <span>{t.footer.allRightsReserved}</span>
    </div>
    <VisitorStats mode="site" />
    <div class="technology-badges" aria-label="博客使用的技术">
      {
        technologyBadges.map(badge => (
          <a
            class="technology-badge"
            href={badge.href}
            target="_blank"
            rel="noopener noreferrer"
            title={`${badge.label}：${badge.value}`}
          >
            <span>{badge.label}</span>
            <strong style={`--badge-color: ${badge.color}`}>{badge.value}</strong>
          </a>
        ))
      }
    </div>
  </div>
</footer>

<style>
  .technology-badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.45rem;
    max-width: 100%;
  }

  .technology-badge {
    display: inline-flex;
    overflow: hidden;
    border-radius: 0.3rem;
    color: white;
    box-shadow: 0 1px 2px rgb(0 0 0 / 15%);
    font-size: 0.72rem;
    line-height: 1.8;
    text-decoration: none;
    transition:
      opacity 150ms ease,
      transform 150ms ease;
  }

  .technology-badge:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .technology-badge span,
  .technology-badge strong {
    padding-inline: 0.45rem;
  }

  .technology-badge span {
    background: #555;
    font-weight: 500;
  }

  .technology-badge strong {
    background: var(--badge-color);
    font-weight: 600;
  }
</style>
