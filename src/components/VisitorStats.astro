---
import type { HTMLAttributes } from "astro/types";

type Props = {
  mode?: "site" | "page";
} & HTMLAttributes<"span">;

const { mode = "site", class: className, ...attrs } = Astro.props;
---

<span
  class:list={["visitor-stats", className]}
  data-visitor-stats
  data-stats-mode={mode}
  aria-live="polite"
  {...attrs}
>
  <span data-stats-content>统计加载中...</span>
</span>

<script>
  import { fetchVisitorStats } from "@/utils/visitorStatsClient.mjs";

  type Stats = {
    siteViews: number;
    siteVisitors: number;
    pageViews: number;
    pageVisitors: number;
  };

  function setupVisitorStats() {
    const API_BASE = "https://status.okisama.top";
    const globalWindow = window as Window & {
      __blogVisitorStats?: {
        requests: Map<string, Promise<Stats>>;
      };
    };
    const state = (globalWindow.__blogVisitorStats ??= {
      requests: new Map(),
    });

    const normalizePath = (path: string) => {
      const normalized = `/${String(path).replace(/^\/+|\/+$/g, "")}`;
      return normalized === "/" ? "/" : `${normalized}/`;
    };

    const recordView = (path: string) => {
      if (!state.requests.has(path)) {
        const request = fetchVisitorStats(fetch, API_BASE, path).catch(
          error => {
            state.requests.delete(path);
            throw error;
          }
        );
        state.requests.set(path, request);
      }
      return state.requests.get(path);
    };

    const renderStats = async () => {
      const elements = document.querySelectorAll<HTMLElement>(
        "[data-visitor-stats]"
      );
      if (!elements.length) return;

      for (const element of elements) {
        element.removeAttribute("hidden");
      }

      try {
        const stats = await recordView(normalizePath(window.location.pathname));
        for (const element of elements) {
          const content = element.querySelector("[data-stats-content]");
          if (!content) continue;
          content.textContent =
            element.dataset.statsMode === "page"
              ? `阅读 ${stats.pageViews} · 读者 ${stats.pageVisitors}`
              : `访问 ${stats.siteViews} · 访客 ${stats.siteVisitors}`;
        }
      } catch {
        for (const element of elements) {
          const content = element.querySelector("[data-stats-content]");
          if (content) content.textContent = "统计暂不可用";
        }
      }
    };

    renderStats();
  }

  setupVisitorStats();
  document.addEventListener("astro:page-load", setupVisitorStats);
</script>

<style>
  .visitor-stats {
    color: var(--muted-foreground);
    font-size: 0.82rem;
    line-height: 1.5;
  }
</style>
