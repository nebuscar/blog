---
type Props = { title: string };
const { title } = Astro.props;
---

<div class="share-actions" data-share-title={title}>
  <span class="italic">分享文章：</span>
  <div class="flex flex-wrap gap-2">
    <button type="button" data-system-share hidden>系统分享</button>
    <button type="button" data-copy-link>复制链接</button>
    <span
      data-copy-status
      class="text-muted-foreground text-sm"
      aria-live="polite"></span>
  </div>
</div>

<script>
  function setupShareActions() {
    const root = document.querySelector<HTMLElement>(".share-actions");
    if (!root) return;
    const systemShare = root.querySelector<HTMLButtonElement>(
      "[data-system-share]"
    );
    const copyLink = root.querySelector<HTMLButtonElement>("[data-copy-link]");
    const status = root.querySelector<HTMLElement>("[data-copy-status]");
    const shareData = {
      title: root.dataset.shareTitle,
      url: window.location.href,
    };

    if (systemShare && navigator.share) {
      systemShare.hidden = false;
      systemShare.onclick = () => navigator.share(shareData).catch(() => {});
    }
    if (copyLink) {
      copyLink.onclick = async () => {
        await navigator.clipboard.writeText(window.location.href);
        if (status) status.textContent = "已复制";
        window.setTimeout(() => {
          if (status) status.textContent = "";
        }, 1600);
      };
    }
  }
  setupShareActions();
  document.addEventListener("astro:page-load", setupShareActions);
</script>

<style>
  .share-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }
  button {
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: var(--muted);
  }
  button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>
