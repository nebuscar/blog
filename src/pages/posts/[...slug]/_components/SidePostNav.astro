---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getPostUrl } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

type AdjacentPost = {
  id: string;
  title: string;
  filePath: string | undefined;
  slug?: string;
} | null;

type Props = {
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

{
  (prevPost || nextPost) && (
    <nav
      data-pagefind-ignore
      aria-label="Post side navigation"
      class="pointer-events-none fixed inset-x-0 top-1/2 z-40 hidden -translate-y-1/2 xl:block"
    >
      <div class="relative mx-auto max-w-[70rem]">
        {prevPost && (
          <a
            href={getPostUrl(
              prevPost.slug,
              prevPost.id,
              prevPost.filePath,
              locale
            )}
            aria-label={`${t.post.previousPost}: ${prevPost.title}`}
            title={prevPost.title}
            class="group pointer-events-auto absolute start-0 flex -translate-x-20 items-center gap-3 no-underline"
          >
            <span class="bg-background/80 text-muted-foreground group-hover:text-accent group-focus-visible:text-accent border-border/60 flex size-11 items-center justify-center rounded-full border shadow-lg backdrop-blur transition">
              <IconArrowLeft class="size-5 rtl:rotate-180" />
            </span>
            <span class="bg-background/90 text-foreground border-border/60 max-w-64 translate-x-2 rounded-md border px-3 py-2 text-sm leading-snug opacity-0 shadow-lg backdrop-blur transition group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 rtl:-translate-x-2 rtl:group-hover:translate-x-0 rtl:group-focus-visible:translate-x-0">
              <span class="text-muted-foreground block text-xs">
                {t.post.previousPost}
              </span>
              <span class="line-clamp-2">{prevPost.title}</span>
            </span>
          </a>
        )}

        {nextPost && (
          <a
            href={getPostUrl(
              nextPost.slug,
              nextPost.id,
              nextPost.filePath,
              locale
            )}
            aria-label={`${t.post.nextPost}: ${nextPost.title}`}
            title={nextPost.title}
            class="group pointer-events-auto absolute end-0 flex translate-x-20 items-center gap-3 no-underline"
          >
            <span class="bg-background/90 text-foreground border-border/60 max-w-64 -translate-x-2 rounded-md border px-3 py-2 text-sm leading-snug opacity-0 shadow-lg backdrop-blur transition group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 rtl:translate-x-2 rtl:group-hover:translate-x-0 rtl:group-focus-visible:translate-x-0">
              <span class="text-muted-foreground block text-xs">
                {t.post.nextPost}
              </span>
              <span class="line-clamp-2">{nextPost.title}</span>
            </span>
            <span class="bg-background/80 text-muted-foreground group-hover:text-accent group-focus-visible:text-accent border-border/60 flex size-11 items-center justify-center rounded-full border shadow-lg backdrop-blur transition">
              <IconArrowRight class="size-5 rtl:rotate-180" />
            </span>
          </a>
        )}
      </div>
    </nav>
  )
}
