---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import IconArrowBarToUp from "@/assets/icons/IconArrowBarToUp.svg";
import IconChevronDown from "@/assets/icons/IconChevronDown.svg";
import IconChevronUp from "@/assets/icons/IconChevronUp.svg";
import IconMessageCircle from "@/assets/icons/IconMessageCircle.svg";
import { getPostUrl } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

type AdjacentPost = {
  id: string;
  title: string;
  filePath: string | undefined;
  slug?: string;
} | null;

type Props = {
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const prevHref = prevPost
  ? getPostUrl(prevPost.slug, prevPost.id, prevPost.filePath, locale)
  : "";
const nextHref = nextPost
  ? getPostUrl(nextPost.slug, nextPost.id, nextPost.filePath, locale)
  : "";
---

<nav
  class="post-context-controls"
  data-post-context-controls
  data-pagefind-ignore
  aria-label="文章上下文导航"
>
  <button
    type="button"
    class="post-context-drag-handle"
    data-post-context-drag-handle
    aria-label="拖动文章工具条"
    title="拖动调整位置，双击恢复默认"
  >
    <span aria-hidden="true"></span>
  </button>

  {
    prevPost ? (
      <a
        href={prevHref}
        data-post-context-prev
        aria-label={`${t.post.previousPost}: ${prevPost.title}`}
        title={`${t.post.previousPost}: ${prevPost.title}`}
      >
        <IconChevronUp class="size-5" />
      </a>
    ) : (
      <span class="context-control-placeholder" aria-hidden="true" />
    )
  }

  <button
    type="button"
    data-post-context-top
    aria-label={t.post.backToTop}
    title={t.post.backToTop}
  >
    <IconArrowBarToUp class="size-5" />
  </button>

  <button
    type="button"
    data-post-context-comments
    aria-label="跳转到评论区"
    title="跳转到评论区"
  >
    <IconMessageCircle class="size-5" />
  </button>

  {
    nextPost ? (
      <a
        href={nextHref}
        data-post-context-next
        aria-label={`${t.post.nextPost}: ${nextPost.title}`}
        title={`${t.post.nextPost}: ${nextPost.title}`}
      >
        <IconChevronDown class="size-5" />
      </a>
    ) : (
      <span class="context-control-placeholder" aria-hidden="true" />
    )
  }
</nav>

<details class="mobile-post-nav" data-mobile-post-nav data-pagefind-ignore>
  <summary aria-label="打开文章导航">
    <span aria-hidden="true">↕</span>
    <span>文章导航</span>
  </summary>
  <div class="mobile-post-nav-panel">
    {
      prevPost && (
        <a href={prevHref}>
          <IconArrowLeft class="size-4 rtl:rotate-180" />
          <span>
            <small>{t.post.previousPost}</small>
            <strong>{prevPost.title}</strong>
          </span>
        </a>
      )
    }
    <button type="button" data-mobile-post-top>
      <IconArrowBarToUp class="size-4" />
      <span>{t.post.backToTop}</span>
    </button>
    <button type="button" data-mobile-post-comments>
      <IconMessageCircle class="size-4" />
      <span>跳转到评论区</span>
    </button>
    {
      nextPost && (
        <a href={nextHref}>
          <span>
            <small>{t.post.nextPost}</small>
            <strong>{nextPost.title}</strong>
          </span>
          <IconArrowRight class="size-4 rtl:rotate-180" />
        </a>
      )
    }
  </div>
</details>

<script>
  import {
    clampContextPosition,
    getDefaultContextPosition,
  } from "@/utils/postContextPosition.mjs";

  function setupPostContextControls() {
    const globalWindow = window as Window & {
      __postNavigationController?: AbortController;
    };
    globalWindow.__postNavigationController?.abort();

    const controller = new AbortController();
    globalWindow.__postNavigationController = controller;
    const previous = document.querySelector<HTMLAnchorElement>(
      "[data-post-context-prev]"
    );
    const next = document.querySelector<HTMLAnchorElement>(
      "[data-post-context-next]"
    );
    const toolbar = document.querySelector<HTMLElement>(
      "[data-post-context-controls]"
    );
    const dragHandle = toolbar?.querySelector<HTMLButtonElement>(
      "[data-post-context-drag-handle]"
    );
    const storageKey = "post-context-position";
    const scrollToTop = () => window.scrollTo({ top: 0, behavior: "smooth" });
    const scrollToComments = () =>
      document
        .querySelector("#comments-title")
        ?.scrollIntoView({ behavior: "smooth", block: "start" });

    document
      .querySelectorAll<HTMLButtonElement>(
        "[data-post-context-top], [data-mobile-post-top]"
      )
      .forEach(button =>
        button.addEventListener("click", scrollToTop, {
          signal: controller.signal,
        })
      );

    document
      .querySelectorAll<HTMLButtonElement>(
        "[data-post-context-comments], [data-mobile-post-comments]"
      )
      .forEach(button =>
        button.addEventListener("click", scrollToComments, {
          signal: controller.signal,
        })
      );

    if (
      toolbar &&
      dragHandle &&
      window.matchMedia("(min-width: 1280px)").matches
    ) {
      const getViewport = () => ({
        width: window.innerWidth,
        height: window.innerHeight,
      });
      const getToolbarSize = () => {
        const rect = toolbar.getBoundingClientRect();
        return { width: rect.width, height: rect.height };
      };
      const applyPosition = (
        position: { x: number; y: number },
        persist = false
      ) => {
        const nextPosition = clampContextPosition(
          position,
          getViewport(),
          getToolbarSize()
        );
        toolbar.style.left = `${nextPosition.x}px`;
        toolbar.style.top = `${nextPosition.y}px`;
        toolbar.style.right = "auto";
        toolbar.style.transform = "none";
        if (persist) {
          localStorage.setItem(storageKey, JSON.stringify(nextPosition));
        }
        return nextPosition;
      };
      const resetPosition = () => {
        localStorage.removeItem(storageKey);
        applyPosition(
          getDefaultContextPosition(getViewport(), getToolbarSize())
        );
      };

      requestAnimationFrame(() => {
        try {
          const saved = JSON.parse(localStorage.getItem(storageKey) ?? "null");
          if (Number.isFinite(saved?.x) && Number.isFinite(saved?.y)) {
            applyPosition(saved);
            return;
          }
        } catch {
          localStorage.removeItem(storageKey);
        }
        resetPosition();
      });

      dragHandle.addEventListener(
        "pointerdown",
        event => {
          event.preventDefault();
          const startRect = toolbar.getBoundingClientRect();
          const startPointer = { x: event.clientX, y: event.clientY };
          dragHandle.setPointerCapture(event.pointerId);
          toolbar.toggleAttribute("data-dragging", true);

          const move = (moveEvent: PointerEvent) => {
            applyPosition({
              x: startRect.left + moveEvent.clientX - startPointer.x,
              y: startRect.top + moveEvent.clientY - startPointer.y,
            });
          };
          const finish = (finishEvent: PointerEvent) => {
            if (dragHandle.hasPointerCapture(finishEvent.pointerId)) {
              dragHandle.releasePointerCapture(finishEvent.pointerId);
            }
            toolbar.removeAttribute("data-dragging");
            dragHandle.removeEventListener("pointermove", move);
            dragHandle.removeEventListener("pointerup", finish);
            dragHandle.removeEventListener("pointercancel", finish);
            applyPosition(
              {
                x: toolbar.offsetLeft,
                y: toolbar.offsetTop,
              },
              true
            );
          };

          dragHandle.addEventListener("pointermove", move);
          dragHandle.addEventListener("pointerup", finish);
          dragHandle.addEventListener("pointercancel", finish);
        },
        { signal: controller.signal }
      );
      dragHandle.addEventListener("dblclick", resetPosition, {
        signal: controller.signal,
      });
      window.addEventListener(
        "resize",
        () =>
          applyPosition({
            x: toolbar.offsetLeft,
            y: toolbar.offsetTop,
          }),
        { signal: controller.signal }
      );
    }

    document.addEventListener(
      "keydown",
      event => {
        if (!event.altKey) return;
        if (event.key === "ArrowLeft" && previous) {
          event.preventDefault();
          window.location.href = previous.href;
        }
        if (event.key === "ArrowRight" && next) {
          event.preventDefault();
          window.location.href = next.href;
        }
        if (event.key === "ArrowUp") {
          event.preventDefault();
          scrollToTop();
        }
      },
      { signal: controller.signal }
    );
  }

  setupPostContextControls();
  document.addEventListener("astro:page-load", setupPostContextControls);
</script>

<style>
  .post-context-controls {
    display: none;
  }

  .mobile-post-nav {
    position: fixed;
    right: 1rem;
    bottom: 5rem;
    z-index: 55;
  }

  .mobile-post-nav summary {
    display: flex;
    cursor: pointer;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    border-radius: 999px;
    padding: 0.55rem 0.75rem;
    color: var(--accent);
    background: color-mix(in srgb, var(--background) 90%, transparent);
    box-shadow: 0 8px 22px rgb(0 0 0 / 14%);
    font-size: 0.75rem;
    font-weight: 600;
    list-style: none;
    backdrop-filter: blur(14px);
  }

  .mobile-post-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-post-nav-panel {
    position: absolute;
    right: 0;
    bottom: calc(100% + 0.55rem);
    display: grid;
    width: min(18rem, calc(100vw - 2rem));
    gap: 0.45rem;
    border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
    border-radius: 1rem;
    padding: 0.55rem;
    background: color-mix(in srgb, var(--background) 94%, transparent);
    box-shadow: 0 12px 28px rgb(0 0 0 / 16%);
    backdrop-filter: blur(18px);
  }

  .mobile-post-nav-panel a,
  .mobile-post-nav-panel button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    border-radius: 0.7rem;
    padding: 0.55rem;
    text-align: left;
    text-decoration: none;
  }

  .mobile-post-nav-panel a:hover,
  .mobile-post-nav-panel button:hover {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .mobile-post-nav-panel span {
    display: grid;
    min-width: 0;
  }

  .mobile-post-nav-panel small {
    color: var(--muted-foreground);
    font-size: 0.68rem;
  }

  .mobile-post-nav-panel strong {
    overflow: hidden;
    font-size: 0.78rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (min-width: 1280px) {
    .post-context-controls {
      position: fixed;
      top: 50%;
      right: 4.75rem;
      z-index: 45;
      display: grid;
      grid-template-rows: 1.1rem repeat(4, 2.5rem);
      justify-content: center;
      gap: 0.4rem;
      border: 1px solid color-mix(in srgb, var(--border) 70%, transparent);
      border-radius: 1rem;
      padding: 0.55rem;
      background: color-mix(in srgb, var(--background) 94%, transparent);
      box-shadow: 0 10px 30px rgb(0 0 0 / 12%);
      backdrop-filter: blur(16px);
      transform: translateY(-50%);
    }

    .post-context-controls a,
    .post-context-controls button,
    .context-control-placeholder {
      display: grid;
      width: 2.5rem;
      height: 2.5rem;
      place-items: center;
      border-radius: 0.65rem;
    }

    .post-context-controls a,
    .post-context-controls button {
      color: var(--muted-foreground);
      background: color-mix(in srgb, var(--muted) 45%, transparent);
      transition:
        color 160ms ease,
        background-color 160ms ease,
        transform 160ms ease;
    }

    .post-context-controls .post-context-drag-handle {
      width: 2.5rem;
      height: 1.1rem;
      cursor: grab;
      touch-action: none;
      background: transparent;
    }

    .post-context-controls .post-context-drag-handle:active,
    .post-context-controls[data-dragging] .post-context-drag-handle {
      cursor: grabbing;
    }

    .post-context-drag-handle span,
    .post-context-drag-handle span::before,
    .post-context-drag-handle span::after {
      width: 0.2rem;
      height: 0.2rem;
      border-radius: 999px;
      background: currentColor;
      box-shadow: 0.35rem 0 currentColor;
    }

    .post-context-drag-handle span {
      position: relative;
      display: block;
      margin-right: 0.35rem;
    }

    .post-context-drag-handle span::before,
    .post-context-drag-handle span::after {
      position: absolute;
      left: 0;
      content: "";
    }

    .post-context-drag-handle span::before {
      top: -0.35rem;
    }

    .post-context-drag-handle span::after {
      top: 0.35rem;
    }

    .post-context-controls a:hover,
    .post-context-controls button:hover {
      color: var(--accent);
      background: color-mix(in srgb, var(--accent) 10%, transparent);
      transform: scale(1.06);
    }

    .context-control-placeholder {
      opacity: 0.25;
      background: color-mix(in srgb, var(--muted) 35%, transparent);
    }

    .mobile-post-nav {
      display: none;
    }
  }
</style>
