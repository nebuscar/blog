---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getPostUrl } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

type AdjacentPost = {
  id: string;
  title: string;
  filePath: string | undefined;
  slug?: string;
} | null;

type Props = {
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const prevHref = prevPost
  ? getPostUrl(prevPost.slug, prevPost.id, prevPost.filePath, locale)
  : "";
const nextHref = nextPost
  ? getPostUrl(nextPost.slug, nextPost.id, nextPost.filePath, locale)
  : "";
---

<nav data-pagefind-ignore aria-label="相邻文章导航">
  <div class="my-8 grid grid-cols-1 gap-4 xl:hidden">
  {
    prevPost && (
      <a
        href={prevHref}
        class="group flex w-full items-center gap-3 rounded-2xl bg-background/80 p-4 shadow-sm ring-1 ring-border/50 backdrop-blur transition hover:text-accent hover:shadow-md"
      >
        <IconArrowLeft class="inline-block size-5 flex-none transition group-hover:-translate-x-1 rtl:rotate-180" />
        <div>
          <span class="text-sm text-muted-foreground">{t.post.previousPost}</span>
          <div class="text-accent/85 font-medium">{prevPost.title}</div>
        </div>
      </a>
    )
  }
  {
    nextPost && (
      <a
        href={nextHref}
        class="group flex w-full items-center justify-end gap-3 rounded-2xl bg-background/80 p-4 text-end shadow-sm ring-1 ring-border/50 backdrop-blur transition hover:text-accent hover:shadow-md"
      >
        <div>
          <span class="text-sm text-muted-foreground">{t.post.nextPost}</span>
          <div class="text-accent/85 font-medium">{nextPost.title}</div>
        </div>
        <IconArrowRight class="inline-block size-5 flex-none transition group-hover:translate-x-1 rtl:rotate-180" />
      </a>
    )
  }
</div>
</nav>
