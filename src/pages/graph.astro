---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import KnowledgeGraph from "@/components/KnowledgeGraph.astro";
import { buildKnowledgeGraph } from "@/utils/knowledgeGraph.mjs";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const locale = Astro.currentLocale ?? config.site.lang;
const graph = buildKnowledgeGraph(posts, post =>
  getPostUrl(post.data.slug, post.id, post.filePath, locale)
);
---

<Layout title={`知识图谱 | ${config.site.title}`} fixedViewport>
  <main id="main-content" class="graph-page">
    <header class="graph-page-header">
      <h1 class="text-accent text-3xl font-bold">知识图谱</h1>
      <p class="text-muted-foreground mt-2">
        根据已发布文章中的 Obsidian WikiLink 自动生成。点击节点可打开文章。
      </p>
    </header>

    <KnowledgeGraph {graph} title="全站关联文档图谱" fullPage />
  </main>
</Layout>

<style>
  .graph-page {
    display: flex;
    width: min(100%, 112rem);
    height: 100svh;
    margin-inline: auto;
    padding-block: 5.25rem 1rem;
    padding-inline: clamp(1rem, 3vw, 2.5rem);
    flex-direction: column;
    overflow: hidden;
  }

  .graph-page-header {
    flex: none;
    margin-block: 0 0.75rem;
  }

  @media (min-width: 1024px) {
    .graph-page {
      width: 100%;
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .graph-page {
      padding-block: 4rem 0.75rem;
    }
  }
</style>
