---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Footer from "@/components/Footer.astro";
import KnowledgeGraph from "@/components/KnowledgeGraph.astro";
import { buildKnowledgeGraph } from "@/utils/knowledgeGraph.mjs";
import { getPostUrl } from "@/utils/getPostPaths";
import config from "@/config";

const posts = await getCollection("posts", ({ data }) => !data.draft);
const locale = Astro.currentLocale ?? config.site.lang;
const graph = buildKnowledgeGraph(posts, post =>
  getPostUrl(post.data.slug, post.id, post.filePath, locale)
);
---

<Layout title={`知识图谱 | ${config.site.title}`}>
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <header class="mt-8 mb-6">
      <h1 class="text-accent text-3xl font-bold">知识图谱</h1>
      <p class="text-muted-foreground mt-2">
        根据已发布文章中的 Obsidian WikiLink 自动生成。点击节点可打开文章。
      </p>
    </header>

    <KnowledgeGraph {graph} title="全站关联文档图谱" />
  </main>
  <Footer />
</Layout>
